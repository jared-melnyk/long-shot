<div class="border border-gray-200 rounded-lg p-4 bg-white shadow-sm">
  <h1 class="text-2xl font-bold text-gray-900 mb-4">Tournaments</h1>
  <% if @tournaments.any? %>
    <ul class="list-disc list-inside space-y-2">
      <% @tournaments.each do |t| %>
        <li><%= link_to t.name, tournament_path(t), class: "text-emerald-600 hover:underline" %> — <%= t.starts_at&.strftime("%b %d, %Y") %></li>
      <% end %>
    </ul>
  <% else %>
    <p class="text-gray-600">No tournaments yet. Tournaments are synced when you make picks or add a pool.</p>
  <% end %>
</div>
