<h1 class="text-2xl font-bold text-gray-900 mb-4">Tournaments</h1>

<ul class="list-disc list-inside space-y-2 mb-6">
  <% @tournaments.each do |t| %>
    <li><%= link_to t.name, tournament_path(t), class: "text-emerald-600 hover:underline" %> — <%= t.starts_at&.strftime("%b %d") %> to <%= t.ends_at&.strftime("%b %d") %></li>
  <% end %>
</ul>
<% if @tournaments.empty? %>
  <p class="text-gray-600 mb-6">No tournaments yet. Sync tournaments from the API.</p>
<% end %>
