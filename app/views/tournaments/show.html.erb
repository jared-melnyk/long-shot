<h1><%= @tournament.name %></h1>
<p><%= @tournament.starts_at&.strftime("%b %d, %Y") %> – <%= @tournament.ends_at&.strftime("%b %d, %Y") %></p>
<% if @tournament.external_id.present? %>
  <p>
    <%= button_to "Sync field", sync_field_path, method: :post, params: { tournament_id: @tournament.id } %>
    <%= button_to "Sync results from API", sync_tournament_results_path(@tournament), method: :post %>
  </p>
<% end %>

<h2>Results</h2>
<ul>
  <% @tournament.tournament_results.includes(:golfer).order(position: :asc).each do |r| %>
    <li><%= r.position %>. <%= r.golfer.name %> — $<%= number_with_delimiter(r.prize_money&.to_i) %>
      <%= button_to "Remove", tournament_result_path(@tournament, r), method: :delete %>
    </li>
  <% end %>
</ul>
<% if @tournament.tournament_results.empty? %>
  <p>No results yet. Add below (e.g. from API or manual entry).</p>
<% end %>

<%= form_with model: [ @tournament, TournamentResult.new ], url: tournament_results_path(@tournament), local: true do |f| %>
  <p><%= f.label :golfer_id, "Golfer" %> <%= f.collection_select :golfer_id, Golfer.order(:name), :id, :name, { include_blank: "Select…" } %></p>
  <p><%= f.label :position %> <%= f.number_field :position, min: 1 %></p>
  <p><%= f.label :prize_money %> <%= f.number_field :prize_money, min: 0, step: 0.01 %></p>
  <p><%= f.submit "Add result" %></p>
<% end %>

<p><%= link_to "Back to tournaments", tournaments_path %></p>
