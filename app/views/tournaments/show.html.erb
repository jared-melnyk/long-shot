<h1 class="text-2xl font-bold text-gray-900 mb-2"><%= @tournament.name %></h1>
<p class="text-gray-600 mb-6"><%= @tournament.starts_at&.strftime("%b %d, %Y") %></p>

<% if @tournament.external_id.present? %>
  <p class="flex gap-2 flex-wrap mb-6">
    <%= button_to "Sync field", sync_field_path, method: :post, params: { tournament_id: @tournament.id }, form: { class: "inline-block" }, class: "rounded px-3 py-1.5 text-sm bg-emerald-600 text-white hover:bg-emerald-700" %>
    <%= button_to "Sync results", sync_tournament_results_path(@tournament), method: :post, form: { class: "inline-block" }, class: "rounded px-3 py-1.5 text-sm bg-emerald-600 text-white hover:bg-emerald-700" %>
  </p>
<% end %>

<section class="mb-6 border border-gray-200 rounded-lg p-4 bg-white shadow-sm">
  <h2 class="text-lg font-semibold text-gray-900 mb-2">Results</h2>
  <ul class="space-y-2">
    <% results_list = @results || @tournament.tournament_results.includes(:golfer).order(position: :asc) %>
    <% results_list.each do |r| %>
      <li class="flex items-center gap-2 flex-wrap">
        <%= display_place(r, results_list) %> — <%= r.golfer.name %> — <%= @tournament.completed? && r.prize_money.present? ? "$#{number_with_delimiter(r.prize_money.to_i)}" : "TBD" %>
      </li>
    <% end %>
  </ul>
  <% if @tournament.tournament_results.empty? %>
    <p class="text-gray-600">No results yet. Field and results can be synced from the API above.</p>
  <% end %>
</section>
