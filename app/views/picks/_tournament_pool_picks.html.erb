<%# Locals: pool, pool_tournament, tournament, picks_by_user (Hash[user_id => Pick]) %>
<section class="mt-2 border border-gray-200 rounded-lg shadow-sm bg-white">
  <header class="px-3 py-2 border-b border-gray-200 bg-gray-50 flex items-center justify-between rounded-t-lg">
    <h3 class="text-sm font-medium text-gray-900">
      Pool picks for <%= tournament.name %>
    </h3>
    <p class="text-xs text-gray-600">
      <% if pool_tournament.can_view_all_picks?(current_user) %>
        All picks are visible because this tournament has started.
      <% elsif tournament.picks_open? %>
        Picks are open. You can see your own picks; others show whether a pick has been submitted.
      <% else %>
        Picks are not open yet. Once picks open, you can see your own picks here.
      <% end %>
    </p>
  </header>

  <div class="overflow-x-auto">
    <table class="min-w-full divide-y divide-gray-200 text-sm">
      <thead class="bg-gray-50">
        <tr>
          <th scope="col" class="px-3 py-2 text-left font-semibold text-gray-700">Member</th>
          <th scope="col" class="px-3 py-2 text-left font-semibold text-gray-700">Picks</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-100 bg-white">
        <% pool.users.order(:name).each do |member| %>
          <% pick = picks_by_user[member.id] %>
          <tr class="align-top">
            <td class="px-3 py-2 whitespace-nowrap text-gray-900">
              <div class="font-medium"><%= member.name %></div>
              <div class="text-xs text-gray-500"><%= member.email %></div>
            </td>
            <td class="px-3 py-2">
              <% if pick.present? %>
                <% if pool_tournament.can_view_all_picks?(current_user) || pool_tournament.can_view_member_picks?(current_user, member) %>
                  <ul class="list-disc list-inside space-y-0.5 text-gray-800">
                    <% pick.pick_golfers.order(:slot).each do |pg| %>
                      <li>
                        <span><%= pg.golfer&.name %></span>
                      </li>
                    <% end %>
                  </ul>
                <% else %>
                  <span class="inline-flex items-center rounded-full bg-emerald-50 px-2 py-0.5 text-xs font-medium text-emerald-700">
                    Pick submitted
                  </span>
                <% end %>
              <% else %>
                <span class="inline-flex items-center rounded-full bg-gray-50 px-2 py-0.5 text-xs font-medium text-gray-600">
                  No pick
                </span>
              <% end %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</section>

