<h1>Pick 5 golfers — <%= @tournament.name %></h1>

<%= form_with url: pool_picks_path(@pool), method: :post, local: true do |f| %>
  <%= hidden_field_tag :tournament_id, @tournament.id %>
  <% 5.times do |i| %>
    <p>
      <label>Slot <%= i + 1 %></label>
      <%= select_tag "golfer_ids[]", options_from_collection_for_select(@golfers, :id, :name, @pick.pick_golfers.find { |pg| pg.slot == i + 1 }&.golfer_id), include_blank: "Select golfer…" %>
    </p>
  <% end %>
  <p><%= submit_tag "Save picks" %></p>
<% end %>

<p><%= link_to "Back to picks", pool_picks_path(@pool) %></p>
