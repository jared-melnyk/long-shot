<h1>Sign in</h1>

<%= form_with url: login_path, method: :post, local: true do |f| %>
  <p>
    <%= f.label :email %>
    <%= f.email_field :email, required: true, autofocus: true %>
  </p>
  <p>
    <%= f.label :password %>
    <%= f.password_field :password, required: true %>
  </p>
  <p><%= f.submit "Sign in" %></p>
<% end %>

<p><%= link_to "Sign up", signup_path %></p>
