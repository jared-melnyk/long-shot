<div class="max-w-md mx-auto border border-gray-200 rounded-lg p-6 bg-white shadow-sm">
  <h1 class="text-2xl font-bold text-gray-900 mb-6">Sign in</h1>

  <%= form_with url: login_path, method: :post, local: true, class: "space-y-4" do |f| %>
    <div>
      <%= f.label :email, class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.email_field :email, required: true, autofocus: true, class: "w-full rounded border border-gray-300 px-3 py-2 focus:ring-2 focus:ring-emerald-500 focus:border-emerald-500" %>
    </div>
    <div>
      <%= f.label :password, class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.password_field :password, required: true, class: "w-full rounded border border-gray-300 px-3 py-2 focus:ring-2 focus:ring-emerald-500 focus:border-emerald-500" %>
    </div>
    <div>
      <%= f.submit "Sign in", class: "bg-emerald-600 text-white px-4 py-2 rounded hover:bg-emerald-700 font-medium" %>
    </div>
  <% end %>

  <p class="mt-4">
    <%= link_to "Forgot password?", forgot_password_path, class: "text-emerald-600 hover:underline" %>
    |
    <%= link_to "Sign up", signup_path, class: "text-emerald-600 hover:underline" %>
  </p>
</div>
