<div class="border border-gray-200 rounded-lg p-6 bg-white shadow-sm">
  <h1 class="text-2xl font-bold text-gray-900 mb-4">My pools</h1>
  <p class="mb-6">
    <%= link_to "New pool", new_pool_path, class: "inline-block bg-emerald-600 text-white px-4 py-2 rounded hover:bg-emerald-700 font-medium no-underline" %>
  </p>
  <% if @pools.any? %>
    <ul class="list-disc list-inside space-y-2">
      <% @pools.each do |pool| %>
        <li><%= link_to pool.name, pool_path(pool), class: "text-emerald-600 hover:underline" %></li>
      <% end %>
    </ul>
  <% else %>
    <p class="text-gray-600">No pools yet. Create one or use an invite link to join a pool.</p>
  <% end %>
</div>
