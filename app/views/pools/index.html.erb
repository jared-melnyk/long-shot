<h1 class="text-2xl font-bold text-gray-900 mb-4">My pools</h1>

<p class="mb-6">
  <%= link_to "New pool", new_pool_path, class: "inline-block bg-emerald-600 text-white px-4 py-2 rounded hover:bg-emerald-700 font-medium no-underline" %>
</p>

<% if @pools.any? %>
  <h2 class="text-lg font-semibold text-gray-900 mt-6 mb-2">My pools</h2>
  <ul class="list-disc list-inside space-y-2">
    <% @pools.each do |pool| %>
      <li><%= link_to pool.name, pool_path(pool), class: "text-emerald-600 hover:underline" %></li>
    <% end %>
  </ul>
<% end %>

<% if @other_pools.any? %>
  <h2 class="text-lg font-semibold text-gray-900 mt-6 mb-2">Other pools</h2>
  <ul class="space-y-2">
    <% @other_pools.each do |pool| %>
      <li class="flex items-center gap-2 flex-wrap">
        <%= link_to pool.name, pool_path(pool), class: "text-emerald-600 hover:underline" %>
        <%= button_to "Join", join_pool_path(pool), method: :post, form: { class: "inline-block" }, class: "rounded px-2 py-1 text-sm bg-emerald-600 text-white hover:bg-emerald-700" %>
      </li>
    <% end %>
  </ul>
<% end %>

<% if @pools.empty? && @other_pools.empty? %>
  <p class="text-gray-600">No pools yet. Create one to get started.</p>
<% end %>
