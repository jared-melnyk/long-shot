<div class="max-w-md mx-auto border border-gray-200 rounded-lg p-6 bg-white shadow-sm">
  <h1 class="text-2xl font-bold text-gray-900 mb-4"><%= @pool.name %></h1>
  <p class="text-gray-600 mb-4">You're not in this pool yet.</p>
  <%= button_to "Join this pool", join_pool_path(@pool), method: :post, class: "bg-emerald-600 text-white px-4 py-2 rounded hover:bg-emerald-700 font-medium" %>
</div>
