<h1 class="text-2xl font-bold text-gray-900 mb-4"><%= @pool.name %></h1>
<% if @pool.start_date.present? %>
  <p class="text-gray-600 mb-4">Starts <%= @pool.start_date.strftime("%B %d, %Y") %></p>
<% end %>
<% if current_user && @pool.users.include?(current_user) %>
  <p class="mb-4">
    <button type="button"
            data-invite-url="<%= pool_url(@pool) %>"
            data-controller="clipboard"
            data-action="click->clipboard#copy"
            class="rounded px-4 py-2 text-sm font-medium bg-emerald-600 text-white hover:bg-emerald-700">
      Invite to pool
    </button>
    <span data-clipboard-target="feedback" class="ml-2 text-sm text-gray-600 hidden">Link copied!</span>
  </p>
<% end %>

<section class="mb-6 border border-gray-200 rounded-lg p-4 bg-white">
  <h2 class="text-lg font-semibold text-gray-900 mb-2">Standings</h2>
  <ol class="list-decimal list-inside space-y-2">
    <% @pool.standings.each_with_index do |(user, total), idx| %>
      <li><%= user.name %> — $<%= number_with_delimiter(total.to_i) %></li>
    <% end %>
  </ol>
  <% if @pool.standings.empty? %>
    <p class="text-gray-600">No picks or results yet.</p>
  <% end %>
</section>

<section class="mb-6 border border-gray-200 rounded-lg p-4 bg-white">
  <h2 class="text-lg font-semibold text-gray-900 mb-2">Tournaments in this pool</h2>
  <ul class="space-y-4">
    <% @pool.tournaments.order(:starts_at).each do |t| %>
      <li class="flex items-start gap-2 flex-wrap border-b border-gray-100 pb-3 last:border-0 last:pb-0">
        <div class="flex-1 min-w-0">
          <%= render "picks/tournament_with_picks", tournament: t, pool: @pool, pick: @my_picks_by_tournament&.[](t.id) %>
        </div>
        <% if @pool.pool_tournaments.exists?(tournament: t) %>
          <%= button_to "Remove", pool_pool_tournament_path(@pool, @pool.pool_tournaments.find_by(tournament: t)), method: :delete, form: { class: "inline-block" }, class: "rounded px-2 py-1 text-sm text-red-600 hover:text-red-700 border border-red-300 hover:border-red-400" %>
        <% end %>
      </li>
    <% end %>
  </ul>
  <% if @pool.tournaments.empty? %>
    <p class="text-gray-600">No tournaments added. Add one below.</p>
  <% end %>
  <%= form_with url: pool_pool_tournaments_path(@pool), method: :post, class: "flex gap-2 items-center mt-3 flex-wrap" do |f| %>
    <% eligible_tournaments = Tournament.addable_to_pool.order(:starts_at) - @pool.tournaments %>
    <%= f.select :tournament_id, options_from_collection_for_select(eligible_tournaments, :id, :name), { include_blank: "Select tournament…" }, { name: "tournament_id", class: "rounded border border-gray-300 px-2 py-1" } %>
    <%= f.submit "Add tournament", class: "rounded px-3 py-1.5 text-sm bg-emerald-600 text-white hover:bg-emerald-700" %>
  <% end %>
</section>

<section class="mb-6 border border-gray-200 rounded-lg p-4 bg-white">
  <h2 class="text-lg font-semibold text-gray-900 mb-2">Members</h2>
  <ul class="space-y-2">
    <% @pool.users.each do |u| %>
      <li class="flex items-center gap-2 flex-wrap">
        <%= u.name %> (<%= u.email %>)
        <% if @pool.pool_users.exists?(user: u) %>
          <%= button_to "Remove", pool_pool_user_path(@pool, @pool.pool_users.find_by(user: u)), method: :delete, form: { class: "inline-block" }, class: "rounded px-2 py-1 text-sm text-red-600 hover:text-red-700 border border-red-300 hover:border-red-400" %>
        <% end %>
      </li>
    <% end %>
  </ul>
  <%= form_with url: pool_pool_users_path(@pool), method: :post, class: "flex gap-2 items-center mt-3 flex-wrap" do |f| %>
    <%= f.select :user_id, options_from_collection_for_select(User.order(:name) - @pool.users, :id, :name), { include_blank: "Select user…" }, { name: "user_id", class: "rounded border border-gray-300 px-2 py-1" } %>
    <%= f.submit "Add member", class: "rounded px-3 py-1.5 text-sm bg-emerald-600 text-white hover:bg-emerald-700" %>
  <% end %>
</section>
