<h1 class="text-2xl font-bold text-gray-900 mb-4"><%= @pool.name %></h1>
<% if @pool.start_date.present? %>
  <p class="text-gray-600 mb-4">Starts <%= @pool.start_date.strftime("%B %d, %Y") %></p>
<% end %>
<% if current_user && @pool.users.include?(current_user) %>
  <p class="mb-4" data-controller="clipboard" data-invite-url="<%= pool_url(@pool) %>">
    <button type="button"
            data-action="click->clipboard#copy"
            class="rounded px-4 py-2 text-sm font-medium bg-emerald-600 text-white hover:bg-emerald-700">
      Invite to pool
    </button>
    <span data-clipboard-target="feedback" class="ml-2 text-sm text-gray-600 hidden">Link copied!</span>
  </p>
<% end %>

<section class="mb-6 border border-gray-200 rounded-lg p-4 bg-white shadow-sm">
  <h2 class="text-lg font-semibold text-gray-900 mb-3">Standings</h2>
  <ol class="list-decimal list-inside space-y-3">
    <% @pool.standings.each_with_index do |(user, total), idx| %>
      <% pu = @pool.pool_users.find_by(user: user) %>
      <li class="flex items-center justify-between gap-2 flex-wrap">
        <span class="flex items-center gap-2">
          <% if idx == 0 %><span class="inline-flex items-center rounded-full bg-amber-100 text-amber-800 text-xs font-medium px-2 py-0.5">1st</span><% end %>
          <%= user.name %> — $<%= number_with_delimiter(total.to_i) %>
        </span>
        <span class="flex items-center gap-2">
          <% if pu && user == current_user %>
            <%= button_to "Leave pool", pool_pool_user_path(@pool, pu), method: :delete, form: { class: "inline-block", data: { turbo_confirm: "Removal cannot be undone. Are you sure?" } }, class: "rounded px-2 py-1 text-xs text-red-600 hover:text-red-700 border border-red-300 hover:border-red-400" %>
          <% elsif pu && @pool.creator?(current_user) %>
            <%= button_to "Remove", pool_pool_user_path(@pool, pu), method: :delete, form: { class: "inline-block", data: { turbo_confirm: "Removal cannot be undone. Are you sure?" } }, class: "rounded px-2 py-1 text-xs text-red-600 hover:text-red-700 border border-red-300 hover:border-red-400" %>
          <% end %>
        </span>
      </li>
    <% end %>
  </ol>
  <% if @pool.standings.empty? %>
    <p class="text-gray-600">No picks or results yet.</p>
  <% end %>
</section>

<section class="mb-6 border border-gray-200 rounded-lg p-4 bg-white shadow-sm">
  <h2 class="text-lg font-semibold text-gray-900 mb-3">Tournaments in this pool</h2>
  <ul class="space-y-4">
    <% @pool.tournaments.order(:starts_at).each do |t| %>
      <% pt = @pool_tournaments.find { |p| p.tournament_id == t.id } %>
      <li class="space-y-3 border-b border-gray-100 pb-3 last:border-0 last:pb-0">
        <div class="flex items-start gap-2 flex-wrap">
          <div class="flex-1 min-w-0">
            <%= render "picks/tournament_with_picks", tournament: t, pool: @pool, pick: @my_picks_by_tournament&.[](t.id), pool_tournament: pt %>
          </div>
          <div class="flex items-center gap-2">
            <% if pt && @pool.creator?(current_user) && !t.started? %>
              <%= button_to "Remove", pool_pool_tournament_path(@pool, pt), method: :delete, form: { class: "inline-block", data: { turbo_confirm: "Removal cannot be undone. Are you sure?" } }, class: "rounded px-2 py-1 text-sm text-red-600 hover:text-red-700 border border-red-300 hover:border-red-400" %>
            <% end %>
            <% if pt && t.started? %>
              <% if t.results_synced_at.present? %>
                <%= link_to "View results",
                            pool_pool_tournament_path(@pool, pt),
                            class: "inline-flex items-center rounded-md px-4 py-2.5 text-sm font-semibold bg-emerald-600 text-white shadow-sm hover:bg-emerald-700 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-emerald-600" %>
              <% else %>
                <%= link_to "Live scores",
                            pool_pool_tournament_path(@pool, pt),
                            class: "inline-flex items-center rounded-md px-4 py-2.5 text-sm font-semibold bg-blue-600 text-white shadow-sm hover:bg-blue-700 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-blue-600" %>
              <% end %>
            <% end %>
          </div>
        </div>

        <% if pt %>
          <%= render "picks/tournament_pool_picks",
            pool: @pool,
            pool_tournament: pt,
            tournament: t,
            picks_by_user: @picks_by_tournament_and_user&.[](t.id) || {} %>
        <% end %>
      </li>
    <% end %>
  </ul>
  <% if @pool.tournaments.empty? %>
    <p class="text-gray-600">No tournaments added. Add one below.</p>
  <% end %>
  <% if @pool.creator?(current_user) %>
    <%= form_with url: pool_pool_tournaments_path(@pool), method: :post, class: "flex gap-2 items-center mt-3 flex-wrap" do |f| %>
      <% eligible_tournaments = Tournament.addable_to_pool.order(:starts_at) - @pool.tournaments %>
      <%= f.select :tournament_id, options_from_collection_for_select(eligible_tournaments, :id, :name), { include_blank: "Select tournament…" }, { name: "tournament_id", class: "rounded border border-gray-300 px-3 py-2 focus:ring-2 focus:ring-emerald-500 focus:border-emerald-500" } %>
      <%= f.submit "Add tournament", class: "rounded px-4 py-2 text-sm font-medium bg-emerald-600 text-white hover:bg-emerald-700" %>
    <% end %>
  <% end %>
</section>

<%# Members section removed; membership is managed via standings row actions %>
