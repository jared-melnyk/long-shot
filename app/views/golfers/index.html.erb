<h1 class="text-2xl font-bold text-gray-900 mb-4">Golfers</h1>

<p class="mb-6">
  <%= link_to "Add golfer", new_golfer_path, class: "inline-block bg-emerald-600 text-white px-4 py-2 rounded hover:bg-emerald-700 font-medium no-underline" %>
</p>

<ul class="list-disc list-inside space-y-2 mb-6">
  <% @golfers.each do |g| %>
    <li><%= g.name %><%= " (ID: #{g.external_id})" if g.external_id.present? %></li>
  <% end %>
</ul>
<% if @golfers.empty? %>
  <p class="text-gray-600 mb-6">No golfers yet. Add some so you can make picks.</p>
<% end %>
